---
import { additionalServiceLinks, company, navLinks } from '../data/site';
import { fireServices } from '../data/fire-services';
import { withBase } from '../utils/paths';

const socialLinks = [
	{ label: 'LinkedIn', href: company.socialLinkedIn },
	{ label: 'Facebook', href: company.socialFacebook },
	{ label: 'Instagram', href: company.socialInstagram }
];

const isRealExternalUrl = (href: string) => href.startsWith('http://') || href.startsWith('https://');
---

<footer class="border-t border-steel-200 bg-steel-900 py-12 text-steel-100">
	<div class="container grid gap-10 md:grid-cols-2 lg:grid-cols-4">
		<div>
			<div class="flex items-center">
				<img
					src={withBase('/logo_white.svg')}
					alt={company.logoAlt}
					width="150"
					height="56"
					loading="lazy"
					decoding="async"
					class="h-14 w-[150px]"
				/>
			</div>
			<p class="mt-3 text-sm text-steel-200">{company.legalName}</p>
			<p class="mt-4 text-sm text-steel-200">{company.location}</p>
			<p class="mt-1 text-sm text-steel-200">Working Hours: {company.workingHours}</p>
			<p class="mt-1 text-sm text-steel-200">Service Area: {company.serviceAreas}</p>
		</div>

		<div>
			<h3 class="text-sm font-semibold uppercase tracking-wider text-white">Contact (Placeholder)</h3>
			<ul class="mt-4 space-y-2 text-sm">
				<li>
					<span class="font-medium">Phone:</span>
					<a href={company.phoneHref} class="ml-1 hover:text-brand">{company.phone}</a>
				</li>
				<li>
					<span class="font-medium">WhatsApp:</span>
					<a href={company.whatsappHref} class="ml-1 hover:text-brand">{company.whatsapp}</a>
				</li>
				<li>
					<span class="font-medium">Email:</span>
					<a href={company.emailHref} class="ml-1 hover:text-brand">{company.email}</a>
				</li>
				<li><span class="font-medium">Address:</span> {company.address}</li>
			</ul>
			<a
				href={withBase('/contact-us')}
				class="mt-4 inline-flex text-sm font-semibold text-steel-100 underline decoration-steel-300 decoration-2 underline-offset-4 transition hover:text-white hover:decoration-white visited:text-steel-100 focus-visible:rounded-sm focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-steel-900"
			>
				Request a Quote
			</a>
		</div>

		<div>
			<h3 class="text-sm font-semibold uppercase tracking-wider text-white">Quick Links</h3>
			<ul class="mt-4 grid grid-cols-2 gap-2 text-sm">
				{navLinks.map((link) => (
					<li><a href={withBase(link.href)} class="hover:text-brand">{link.label}</a></li>
				))}
			</ul>
			<h3 class="mt-6 text-sm font-semibold uppercase tracking-wider text-white">Service Links</h3>
			<ul class="mt-3 space-y-2 text-sm">
				{fireServices.map((service) => (
					<li><a href={withBase(service.href)} class="hover:text-brand">{service.title}</a></li>
				))}
			</ul>
			<h3 class="mt-6 text-sm font-semibold uppercase tracking-wider text-white">Additional Services</h3>
			<ul class="mt-3 space-y-2 text-sm">
				{additionalServiceLinks.map((link) => (
					<li><a href={withBase(link.href)} class="hover:text-brand">{link.label}</a></li>
				))}
			</ul>
		</div>

		<div>
			<h3 class="text-sm font-semibold uppercase tracking-wider text-white">Social (Placeholder)</h3>
			<ul class="mt-4 space-y-2 text-sm text-steel-200">
				{socialLinks.map((social) => (
					<li>
						{isRealExternalUrl(social.href) ? (
							<a href={social.href} class="hover:text-brand" target="_blank" rel="noreferrer">{social.label}</a>
						) : (
							<span>{social.label} (To Be Updated)</span>
						)}
					</li>
				))}
			</ul>
			<h3 class="mt-6 text-sm font-semibold uppercase tracking-wider text-white">Inquiry Note</h3>
			<p class="mt-4 text-sm text-steel-200">
				For quotations and technical support, use the contact placeholders for now. Replace with final phone,
				WhatsApp, email, and map link before launch.
			</p>
		</div>
	</div>
	<div class="container mt-10 border-t border-steel-700 pt-6 text-xs text-steel-300">
		<p>&copy; {new Date().getFullYear()} {company.brandName}. All rights reserved.</p>
	</div>
</footer>

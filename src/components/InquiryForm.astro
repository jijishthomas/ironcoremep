---
---

<form class="card-base p-6" aria-describedby="form-note">
	<h2 class="text-2xl font-semibold text-steel-900">Send an Inquiry</h2>
	<p class="mt-2 text-sm text-steel-600">
		Submit your requirement details. Form backend integration is pending for launch setup.
	</p>
	<div class="mt-5 grid gap-4 md:grid-cols-2">
		<label class="text-sm font-medium text-steel-700">
			Name
			<input id="inquiry-name" autocomplete="name" class="mt-1 w-full rounded-lg border border-steel-300 px-3 py-2 text-sm focus:border-brand focus:outline-none focus:ring-2 focus:ring-brand/30" type="text" name="name" placeholder="Your name" />
		</label>
		<label class="text-sm font-medium text-steel-700">
			Company / Organization
			<input id="inquiry-company" autocomplete="organization" class="mt-1 w-full rounded-lg border border-steel-300 px-3 py-2 text-sm focus:border-brand focus:outline-none focus:ring-2 focus:ring-brand/30" type="text" name="company" placeholder="Company name" />
		</label>
		<label class="text-sm font-medium text-steel-700">
			Phone Number
			<input id="inquiry-phone" autocomplete="tel" class="mt-1 w-full rounded-lg border border-steel-300 px-3 py-2 text-sm focus:border-brand focus:outline-none focus:ring-2 focus:ring-brand/30" type="tel" name="phone" placeholder="+971 XX XXX XXXX" />
		</label>
		<label class="text-sm font-medium text-steel-700">
			Email Address
			<input id="inquiry-email" autocomplete="email" class="mt-1 w-full rounded-lg border border-steel-300 px-3 py-2 text-sm focus:border-brand focus:outline-none focus:ring-2 focus:ring-brand/30" type="email" name="email" placeholder="info@ironcoremep.example" />
		</label>
		<label class="text-sm font-medium text-steel-700 md:col-span-2">
			Service Required
			<select id="inquiry-service" class="mt-1 w-full rounded-lg border border-steel-300 px-3 py-2 text-sm focus:border-brand focus:outline-none focus:ring-2 focus:ring-brand/30" name="service">
				<option>HVAC Services</option>
				<option>Fire Alarm Systems</option>
				<option>Electromechanical Works</option>
				<option>Building Maintenance</option>
				<option>Project Support Inquiry</option>
			</select>
		</label>
		<label class="text-sm font-medium text-steel-700 md:col-span-2">
			Message
			<textarea id="inquiry-message" class="mt-1 min-h-32 w-full rounded-lg border border-steel-300 px-3 py-2 text-sm focus:border-brand focus:outline-none focus:ring-2 focus:ring-brand/30" name="message" placeholder="Briefly describe your requirement, location, and expected timeline."></textarea>
		</label>
	</div>
	<button type="button" class="mt-5 w-full rounded-lg bg-brand px-5 py-3 text-sm font-semibold text-white md:w-auto" aria-disabled="true">
		Request a Quote (Form Setup Pending)
	</button>
	<p id="form-note" class="mt-3 text-xs text-steel-500" role="status">
		This form is currently UI-only. For immediate response, use phone, WhatsApp, or email placeholders shown on this page.
	</p>
</form>

---
import { ctaLabels, navLinks } from '../data/site';
import { withBase } from '../utils/paths';

interface Props {
	currentPath: string;
}

const { currentPath } = Astro.props;
---

<details class="relative lg:hidden">
	<summary
		aria-label="Open navigation menu"
		class="cursor-pointer list-none rounded-md border border-steel-300 px-3 py-2 text-sm font-medium text-steel-800"
	>
		Menu
	</summary>
	<nav
		aria-label="Mobile navigation"
		class="absolute right-0 mt-2 w-72 max-w-[calc(100vw-2rem)] rounded-xl border border-steel-200 bg-white p-4 shadow-shell"
	>
		<ul class="space-y-3">
			{navLinks.map((link) => (
				<li>
					<a
						href={withBase(link.href)}
						aria-current={currentPath === link.href ? 'page' : undefined}
						class={`block rounded-md px-3 py-2 text-sm font-medium ${currentPath === link.href ? 'bg-brand-soft text-brand' : 'text-steel-700 hover:bg-steel-100'}`}
					>
						{link.label}
					</a>
				</li>
			))}
			<li class="pt-2">
				<a
					href={withBase('/contact-us')}
					class="block rounded-md bg-brand px-3 py-2 text-center text-sm font-semibold text-white hover:bg-brand-dark"
				>
					{ctaLabels.primary}
				</a>
			</li>
		</ul>
	</nav>
</details>

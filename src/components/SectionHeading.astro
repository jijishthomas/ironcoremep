---
interface Props {
	eyebrow?: string;
	title: string;
	description?: string;
	align?: 'left' | 'center';
}

const { eyebrow, title, description, align = 'left' } = Astro.props;
const alignment = align === 'center' ? 'text-center mx-auto' : 'text-left';
---

<div class={`max-w-3xl ${alignment}`}>
	{eyebrow && <p class="mb-3 text-sm font-semibold uppercase tracking-[0.18em] text-brand">{eyebrow}</p>}
	<h2 class="text-3xl font-bold leading-tight text-steel-900 md:text-4xl">{title}</h2>
	{description && <p class="mt-4 prose-copy">{description}</p>}
</div>

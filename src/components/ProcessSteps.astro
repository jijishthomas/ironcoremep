---
interface Step {
	title: string;
	description: string;
}

interface Props {
	steps: Step[];
}

const { steps } = Astro.props;
---

<ol class="grid gap-4 md:grid-cols-2">
	{steps.map((step, index) => (
		<li class="card-base p-6">
			<p class="text-xs font-semibold uppercase tracking-[0.18em] text-brand">Step {index + 1}</p>
			<h3 class="mt-2 text-xl font-semibold text-steel-900">{step.title}</h3>
			<p class="mt-3 text-sm leading-7 text-steel-600">{step.description}</p>
		</li>
	))}
</ol>

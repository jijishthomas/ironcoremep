---
interface Props {
	title: string;
	description: string;
}

const { title, description } = Astro.props;
---

<aside class="rounded-2xl border border-dashed border-brand/60 bg-brand-soft p-6">
	<h2 class="text-xl font-semibold text-steel-900">{title}</h2>
	<p class="mt-3 text-sm leading-7 text-steel-700">{description}</p>
</aside>

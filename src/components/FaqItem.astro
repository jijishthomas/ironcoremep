---
interface Props {
	question: string;
	answer: string;
}

const { question, answer } = Astro.props;
---

<details class="group rounded-xl border border-steel-200 bg-white p-5">
	<summary class="cursor-pointer list-none pr-8 text-base font-semibold text-steel-900">
		{question}
	</summary>
	<p class="mt-3 text-sm leading-7 text-steel-600">{answer}</p>
</details>

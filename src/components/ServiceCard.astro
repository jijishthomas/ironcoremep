---
import { withBase } from '../utils/paths';

interface Props {
	title: string;
	description: string;
	points?: string[];
	href: string;
}

const { title, description, points = [], href } = Astro.props;
---

<article class="card-base p-6">
	<h3 class="text-xl font-semibold text-steel-900">{title}</h3>
	<p class="mt-3 prose-copy">{description}</p>
	{points.length > 0 && (
		<ul class="mt-4 space-y-2 text-sm text-steel-700">
			{points.map((point) => (
				<li class="flex items-start gap-2">
					<span class="mt-1 h-2 w-2 rounded-full bg-brand"></span>
					<span>{point}</span>
				</li>
			))}
		</ul>
	)}
	<a href={withBase(href)} class="mt-6 inline-flex text-sm font-semibold text-brand hover:text-brand-dark">
		Learn more<span class="sr-only"> about {title}</span>
	</a>
</article>

---
import MainLayout from '../layouts/MainLayout.astro';
import PageHero from '../components/PageHero.astro';
import SectionHeading from '../components/SectionHeading.astro';
import ContactInfoCard from '../components/ContactInfoCard.astro';
import InquiryForm from '../components/InquiryForm.astro';
import FaqItem from '../components/FaqItem.astro';
import CtaBanner from '../components/CtaBanner.astro';
import { company, ctaLabels } from '../data/site';
import { fireServices, serviceDeliveryLifecycle } from '../data/fire-services';
import { withBase } from '../utils/paths';
---

<MainLayout
  title="Contact IronCore MEP | Fire Safety Consultation, Installation & AMC"
  description="Contact IronCore MEP for fire alarm, suppression, sprinkler, pump, emergency lighting, AMC, and Civil Defence approval support in Abu Dhabi."
>
  <PageHero
    title="Contact IronCore MEP"
    description="Reach out for fire safety consultations, system installation planning, testing and commissioning support, AMC programs, and Civil Defence approval coordination."
  />

  <section class="section-space">
    <div class="container">
      <SectionHeading
        eyebrow="Contact Information"
        title="Get in touch using phone, WhatsApp, or email placeholders"
        description="Contact placeholders are intentionally used in this milestone and can be replaced quickly before launch."
      />
      <div class="mt-8 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
        <ContactInfoCard label="Call Us" value={company.phone} note="Replace with final direct contact number." href={company.phoneHref} />
        <ContactInfoCard label="WhatsApp Us" value={company.whatsapp} note="Replace with final WhatsApp business number." href={company.whatsappHref} />
        <ContactInfoCard label="Email Us" value={company.email} note="Replace with final inquiry email address." href={company.emailHref} />
        <ContactInfoCard label="Address" value={company.address} note="Primary location context: Musafha, Abu Dhabi." href={company.mapLink} />
        <ContactInfoCard label="Working Hours" value={company.workingHours} note="Office and support schedule." />
        <ContactInfoCard label="Service Area" value={company.serviceAreas} note="Technical support coverage context." />
      </div>
    </div>
  </section>

  <section class="section-space bg-steel-50">
    <div class="container grid gap-8 lg:grid-cols-[1fr_1fr] lg:items-start">
      <div class="card-base p-6">
        <h2 class="text-2xl font-semibold text-steel-900">Location & Service Reach</h2>
        <p class="mt-4 prose-copy">
          IronCore MEP operates from {company.location} and supports both onshore and offshore requirements. Our team
          coordinates fire safety scope across alarm, suppression, sprinkler, firefighting equipment, emergency lighting,
          pump systems, AMC, and Civil Defence approvals.
        </p>
        <p class="mt-4 prose-copy">
          For faster response, share your site type, required system scope, and whether you need design, installation,
          testing and commissioning, maintenance, or approval support.
        </p>
        <div class="mt-5 flex flex-wrap gap-3">
          <a href={withBase('/services')} class="rounded-lg border border-steel-300 px-4 py-2 text-sm font-semibold text-steel-800 hover:border-brand hover:text-brand">
            View All Services
          </a>
          <a href={withBase('/projects')} class="rounded-lg border border-steel-300 px-4 py-2 text-sm font-semibold text-steel-800 hover:border-brand hover:text-brand">
            View Project Applications
          </a>
          <a href={company.mapLink} class="rounded-lg border border-steel-300 px-4 py-2 text-sm font-semibold text-steel-800 hover:border-brand hover:text-brand">
            View Map Placeholder
          </a>
        </div>
      </div>
      <div class="grid gap-4">
        <div class="card-base bg-steel-900 p-6 text-white">
          <h2 class="text-xl font-semibold">Quick Contact Actions</h2>
          <div class="mt-4 grid gap-3 sm:grid-cols-2">
            <a href={company.phoneHref} class="rounded-lg bg-brand px-4 py-3 text-center text-sm font-semibold text-white hover:bg-brand-dark">Call Us</a>
            <a href={company.whatsappHref} class="rounded-lg bg-brand px-4 py-3 text-center text-sm font-semibold text-white hover:bg-brand-dark">WhatsApp Us</a>
            <a href={company.emailHref} class="rounded-lg bg-brand px-4 py-3 text-center text-sm font-semibold text-white hover:bg-brand-dark">Email Us</a>
            <a href={withBase('/services')} class="rounded-lg bg-brand px-4 py-3 text-center text-sm font-semibold text-white hover:bg-brand-dark">{ctaLabels.primary}</a>
          </div>
        </div>
        <div class="card-base p-6">
          <h2 class="text-xl font-semibold text-steel-900">Consultation Areas</h2>
          <ul class="mt-3 space-y-2 text-sm text-steel-600">
            {serviceDeliveryLifecycle.map((item) => (
              <li class="flex items-start gap-2">
                <span class="mt-1 h-2 w-2 rounded-full bg-brand"></span>
                <span>{item.title}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="section-space">
    <div class="container grid gap-8 lg:grid-cols-[1.1fr_0.9fr] lg:items-start">
      <InquiryForm />
      <div class="space-y-4">
        <SectionHeading
          eyebrow="Contact FAQ"
          title="Helpful inquiry questions"
        />
        <FaqItem
          question="What services can I inquire about?"
          answer="You can inquire about all fire safety services including fire alarm, suppression, firefighting equipment, sprinkler systems, emergency lighting, AMC, Civil Defence approvals, and fire pump systems."
        />
        <FaqItem
          question="Do you support design, installation, and testing & commissioning?"
          answer="Yes. We support the full lifecycle from design and consultations through installation, testing and commissioning, and maintenance."
        />
        <FaqItem
          question="Can you support Annual Maintenance Contracts (AMC)?"
          answer="Yes. AMC services include regular inspections, preventive maintenance, performance tests, and reporting support for audit readiness."
        />
        <FaqItem
          question="Can I contact you for Civil Defence approval coordination?"
          answer="Yes. We support documentation preparation, inspection readiness, and final certification process coordination."
        />
      </div>
    </div>
  </section>

  <section class="section-space bg-steel-50">
    <div class="container">
      <SectionHeading eyebrow="Primary Services" title="Request support for any core fire safety category" />
      <div class="mt-8 grid gap-4 sm:grid-cols-2">
        {fireServices.map((service) => (
          <a href={withBase(service.href)} class="rounded-xl border border-steel-200 bg-white p-4 text-sm font-semibold text-steel-700 transition hover:border-brand hover:text-brand">
            {service.title}
          </a>
        ))}
      </div>
    </div>
  </section>

  <CtaBanner
    title="Ready to discuss your fire safety requirement?"
    description="Contact IronCore MEP for site assessment, installation planning, AMC support, and Civil Defence coordination."
    primaryHref="/services"
    primaryLabel={ctaLabels.primary}
    secondaryHref="/projects"
    secondaryLabel="View Project Applications"
  />
</MainLayout>

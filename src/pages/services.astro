---
import MainLayout from '../layouts/MainLayout.astro';
import PageHero from '../components/PageHero.astro';
import SectionHeading from '../components/SectionHeading.astro';
import ServiceCard from '../components/ServiceCard.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import FeatureCard from '../components/FeatureCard.astro';
import CtaBanner from '../components/CtaBanner.astro';
import {
  fireServices,
  planningSupportPoints,
  serviceDeliveryLifecycle,
  systemsCoverage
} from '../data/fire-services';

const processSteps = [
  {
    title: 'Site Review & Consultation',
    description: 'We assess risk profile, occupancy, and system requirements before defining scope.'
  },
  {
    title: 'Design, Supply & Installation',
    description: 'Selected systems are designed, supplied, and installed to match project and operational needs.'
  },
  {
    title: 'Testing & Commissioning',
    description: 'Functional checks and commissioning activities confirm performance and readiness.'
  },
  {
    title: 'AMC & Approval Coordination',
    description: 'Preventive maintenance and Civil Defence approval support keep systems compliant and serviceable.'
  }
];
---

<MainLayout
  title="Fire Safety Services in Abu Dhabi | Installation, Testing, AMC & Approvals"
  description="Explore complete fire safety services including fire alarm, suppression, firefighting equipment, sprinkler, emergency lighting, AMC, Civil Defence approvals, and fire pump systems."
>
  <PageHero
    title="Fire Safety Services"
    description="Our services cover the full fire protection lifecycle: design and consultations, supply, installation, testing and commissioning, maintenance, and Civil Defence approval support."
  />

  <section class="section-space">
    <div class="container grid gap-8 lg:grid-cols-[1.1fr_0.9fr] lg:items-center">
      <div>
        <SectionHeading
          eyebrow="Service Overview"
          title="Complete fire protection support across systems and lifecycle stages"
          description="We deliver coordinated technical support for core fire safety systems with practical execution and compliance-focused documentation."
        />
      </div>
      <div class="card-base p-7">
        <h2 class="text-xl font-semibold text-steel-900">Planning & Consultation Scope</h2>
        <ul class="mt-4 space-y-2 text-sm text-steel-700">
          {planningSupportPoints.map((item) => (
            <li class="flex items-start gap-2">
              <span class="mt-1 h-2 w-2 rounded-full bg-brand"></span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <section class="section-space bg-steel-50">
    <div class="container">
      <SectionHeading
        eyebrow="Primary Service Categories"
        title="All core fire safety services"
      />
      <div class="mt-8 grid gap-6 md:grid-cols-2">
        {fireServices.map((service) => (
          <ServiceCard
            title={service.title}
            description={service.cardSummary}
            points={service.cardPoints}
            href={service.href}
          />
        ))}
      </div>
    </div>
  </section>

  <section class="section-space">
    <div class="container">
      <SectionHeading
        eyebrow="Lifecycle Delivery"
        title="How we support projects and ongoing operations"
      />
      <div class="mt-8 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {serviceDeliveryLifecycle.map((item) => (
          <FeatureCard title={item.title} description={item.description} />
        ))}
      </div>
    </div>
  </section>

  <section class="section-space bg-steel-50">
    <div class="container">
      <SectionHeading
        eyebrow="Systems & Products"
        title="Coverage across active protection systems and supporting products"
      />
      <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {systemsCoverage.map((item) => (
          <div class="rounded-xl border border-steel-200 bg-white p-4 text-sm font-semibold text-steel-700">{item}</div>
        ))}
      </div>
    </div>
  </section>

  <section class="section-space">
    <div class="container">
      <SectionHeading
        eyebrow="Delivery Process"
        title="Simple process with clear execution checkpoints"
      />
      <div class="mt-8">
        <ProcessSteps steps={processSteps} />
      </div>
    </div>
  </section>

  <CtaBanner
    title="Need support for a new installation or system upgrade?"
    description="Talk to our team about fire safety consultations, product supply, testing and commissioning, AMC, or Civil Defence approval coordination."
    primaryHref="/contact-us"
    primaryLabel="Request a Site Assessment"
    secondaryHref="/fire-alarm-systems"
    secondaryLabel="Explore Fire Alarm Systems"
  />
</MainLayout>

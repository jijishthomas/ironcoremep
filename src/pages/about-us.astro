---
import MainLayout from '../layouts/MainLayout.astro';
import PageHero from '../components/PageHero.astro';
import SectionHeading from '../components/SectionHeading.astro';
import FeatureCard from '../components/FeatureCard.astro';
import CtaBanner from '../components/CtaBanner.astro';
import { fireServices, serviceDeliveryLifecycle } from '../data/fire-services';

const industries = [
  'Commercial Buildings',
  'Industrial Facilities',
  'Office Spaces',
  'Warehouses',
  'Residential Properties',
  'Hospitality Facilities',
  'Onshore Operations',
  'Offshore Operations'
];
---

<MainLayout
  title="About IronCore MEP | Fire Safety Systems Company in Abu Dhabi"
  description="IronCore MEP is a Musafha, Abu Dhabi-based technical team providing fire safety design, installation, testing, maintenance, and Civil Defence approval support."
>
  <PageHero
    title="About IronCore MEP"
    description="IronCore MEP is a technical services company based in Musafha, Abu Dhabi, focused on practical fire safety system delivery and long-term maintenance support."
  />

  <section class="section-space">
    <div class="container grid gap-8 lg:grid-cols-[1.2fr_0.8fr] lg:items-start">
      <div>
        <SectionHeading
          eyebrow="Company Overview"
          title="Fire safety execution built around real site requirements"
          description="IRON CORE ELECTROMECHANICAL WORKS AND BUILDING MAINTENANCE - L.L.C delivers fire safety services with clear scope control, practical coordination, and compliance-oriented documentation support."
        />
      </div>
      <div class="card-base bg-steel-900 p-7 text-white">
        <h2 class="text-xl font-semibold">Operating Profile</h2>
        <ul class="mt-4 space-y-2 text-sm text-steel-100">
          <li><span class="font-semibold">Location:</span> Musafha, Abu Dhabi</li>
          <li><span class="font-semibold">Working Hours:</span> 8:00 AM to 5:00 PM</li>
          <li><span class="font-semibold">Service Areas:</span> Onshore & Offshore</li>
        </ul>
        <a href="/contact-us" class="mt-5 inline-flex text-sm font-semibold text-brand">
          Discuss your requirement
        </a>
      </div>
    </div>
  </section>

  <section class="section-space bg-steel-50">
    <div class="container">
      <SectionHeading
        eyebrow="How We Deliver"
        title="Execution philosophy focused on reliability and maintainability"
      />
      <div class="mt-8 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {serviceDeliveryLifecycle.map((item) => (
          <FeatureCard title={item.title} description={item.description} />
        ))}
      </div>
    </div>
  </section>

  <section class="section-space">
    <div class="container">
      <SectionHeading
        eyebrow="Primary Service Categories"
        title="Core fire safety capabilities"
      />
      <div class="mt-8 grid gap-5 md:grid-cols-2">
        {fireServices.map((item) => (
          <a href={item.href} class="card-base block p-6 transition hover:border-brand hover:-translate-y-1">
            <h3 class="text-xl font-semibold text-steel-900">{item.title}</h3>
            <p class="mt-3 text-sm leading-7 text-steel-600">{item.cardSummary}</p>
            <p class="mt-4 text-sm font-semibold text-brand">View service details</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section-space bg-steel-50">
    <div class="container">
      <SectionHeading
        eyebrow="Where We Support"
        title="Service delivery across varied facility contexts"
      />
      <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {industries.map((industry) => (
          <div class="rounded-xl border border-steel-200 bg-white p-4 text-center text-sm font-semibold text-steel-700">
            {industry}
          </div>
        ))}
      </div>
    </div>
  </section>

  <CtaBanner
    title="Need support for fire safety planning or upgrades?"
    description="Connect with IronCore MEP to discuss system design, installation, testing and commissioning, AMC, and Civil Defence approval support."
    primaryHref="/contact-us"
    primaryLabel="Request a Site Assessment"
    secondaryHref="/services"
    secondaryLabel="View Services"
  />
</MainLayout>

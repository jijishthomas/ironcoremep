---
import MainLayout from '../layouts/MainLayout.astro';
import PrimaryButton from '../components/PrimaryButton.astro';
import SecondaryButton from '../components/SecondaryButton.astro';
---

<MainLayout
	title="Page Not Found | IronCore MEP"
	description="The page you requested could not be found. Navigate back to IronCore MEP services, projects, or contact page."
	noindex={true}
>
	<section class="section-space">
		<div class="container">
			<div class="mx-auto max-w-3xl card-base p-8 text-center md:p-12">
				<p class="text-sm font-semibold uppercase tracking-[0.18em] text-brand">404</p>
				<h1 class="mt-3 text-4xl font-bold text-steel-900 md:text-5xl">Page Not Found</h1>
				<p class="mt-4 prose-copy">
					The link may be outdated or the page may have moved. You can continue using the links below to access
					key sections.
				</p>
				<div class="mt-8 flex flex-wrap justify-center gap-3">
					<PrimaryButton href="/" label="Go to Home" />
					<SecondaryButton href="/services" label="View Services" />
					<SecondaryButton href="/contact-us" label="Contact Us" />
				</div>
			</div>
		</div>
	</section>
</MainLayout>

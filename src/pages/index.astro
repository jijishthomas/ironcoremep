---
import MainLayout from '../layouts/MainLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import PrimaryButton from '../components/PrimaryButton.astro';
import SecondaryButton from '../components/SecondaryButton.astro';
import ServiceCard from '../components/ServiceCard.astro';
import FeatureCard from '../components/FeatureCard.astro';
import CtaBanner from '../components/CtaBanner.astro';
import {
  fireServiceBySlug,
  homeFeaturedServiceSlugs,
  planningSupportPoints,
  serviceDeliveryLifecycle,
  systemsCoverage
} from '../data/fire-services';

const featuredServices = homeFeaturedServiceSlugs.map((slug) => fireServiceBySlug[slug]).filter(Boolean);
---

<MainLayout
  title="IronCore MEP | Fire Safety Systems, Installation, AMC & Civil Defence Support"
  description="IronCore MEP provides fire alarm, suppression, sprinkler, firefighting equipment, emergency lighting, fire pump systems, AMC, and Civil Defence approval support in Abu Dhabi."
>
  <section class="relative overflow-hidden bg-steel-900 py-24 text-white">
    <div class="absolute inset-0 opacity-30">
      <div class="h-full w-full bg-[radial-gradient(circle_at_top_left,#c1252d,transparent_45%),radial-gradient(circle_at_bottom_right,#374151,transparent_50%)]"></div>
    </div>
    <div class="container relative grid gap-10 lg:grid-cols-[1.2fr_0.8fr] lg:items-center">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-brand">Musafha, Abu Dhabi</p>
        <h1 class="mt-5 text-4xl font-extrabold leading-tight md:text-6xl">
          End-to-End Fire Safety Systems for Buildings and Industrial Facilities
        </h1>
        <p class="mt-6 max-w-2xl text-lg text-steel-100/90">
          We support the full fire safety lifecycle: design and consultations, product supply, installation,
          testing and commissioning, annual maintenance, and Civil Defence approval coordination.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <PrimaryButton href="/contact-us" label="Request a Site Assessment" />
          <SecondaryButton href="/services" label="Explore Services" />
        </div>
      </div>
      <div class="card-base border-steel-700 bg-white/95 p-8 text-steel-800">
        <h2 class="text-xl font-semibold text-steel-900">Service Snapshot</h2>
        <ul class="mt-5 space-y-3 text-sm">
          <li class="flex items-center justify-between border-b border-steel-200 pb-2">
            <span>Location</span>
            <span class="font-semibold">Musafha, Abu Dhabi</span>
          </li>
          <li class="flex items-center justify-between border-b border-steel-200 pb-2">
            <span>Working Hours</span>
            <span class="font-semibold">8:00 AM to 5:00 PM</span>
          </li>
          <li class="flex items-center justify-between border-b border-steel-200 pb-2">
            <span>Service Area</span>
            <span class="font-semibold">Onshore & Offshore</span>
          </li>
        </ul>
        <a href="/services" class="mt-6 inline-flex text-sm font-semibold text-brand hover:text-brand-dark">
          View all fire safety services
        </a>
      </div>
    </div>
  </section>

  <section class="border-y border-steel-200 bg-steel-50 py-6">
    <div class="container grid gap-4 text-sm font-semibold text-steel-700 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-6">
      <p>Fire Alarm Systems</p>
      <p>Fire Suppression Systems</p>
      <p>Fire Sprinkler Systems</p>
      <p>Fire Pump Systems</p>
      <p>Annual Maintenance Contracts</p>
      <p>Civil Defence Approvals</p>
    </div>
  </section>

  <section class="section-space">
    <div class="container grid gap-10 lg:grid-cols-[1fr_1fr] lg:items-center">
      <div>
        <SectionHeading
          eyebrow="Service Model"
          title="Integrated delivery from planning to long-term support"
          description="Our team coordinates fire safety projects through design, installation, testing, commissioning, and maintenance with practical, compliance-oriented execution."
        />
      </div>
      <div class="card-base p-8">
        <h3 class="text-2xl font-semibold text-steel-900">Consultation and Planning Focus</h3>
        <ul class="mt-4 space-y-2 text-sm text-steel-700">
          {planningSupportPoints.map((item) => (
            <li class="flex items-start gap-2">
              <span class="mt-1 h-2 w-2 rounded-full bg-brand"></span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <section class="section-space bg-steel-50">
    <div class="container">
      <SectionHeading
        eyebrow="Core Services"
        title="Primary fire safety service categories"
        description="A focused service portfolio covering design, installation, testing, compliance support, and ongoing system reliability."
      />
      <div class="mt-10 grid gap-6 md:grid-cols-2">
        {featuredServices.map((service) => (
          <ServiceCard
            title={service.title}
            description={service.cardSummary}
            points={service.cardPoints}
            href={service.href}
          />
        ))}
      </div>
      <div class="mt-8 text-center">
        <a href="/services" class="inline-flex text-sm font-semibold text-brand hover:text-brand-dark">View all 8 services</a>
      </div>
    </div>
  </section>

  <section class="section-space">
    <div class="container">
      <SectionHeading
        eyebrow="Systems Coverage"
        title="Fire safety systems and products we support"
      />
      <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {systemsCoverage.map((item) => (
          <div class="rounded-xl border border-steel-200 bg-white p-4 text-sm font-semibold text-steel-700">{item}</div>
        ))}
      </div>
    </div>
  </section>

  <section class="section-space bg-steel-50">
    <div class="container">
      <SectionHeading
        eyebrow="Delivery Lifecycle"
        title="How we execute fire safety scope"
        description="Each project follows a structured lifecycle to keep installation quality, testing rigor, and approval readiness aligned."
      />
      <div class="mt-8 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {serviceDeliveryLifecycle.map((item) => (
          <FeatureCard title={item.title} description={item.description} />
        ))}
      </div>
    </div>
  </section>

  <CtaBanner
    title="Need support for installation, AMC, or approvals?"
    description="Discuss your site requirements for fire alarm, suppression, sprinkler, pump, emergency lighting, and Civil Defence coordination."
    primaryHref="/contact-us"
    primaryLabel="Get a Fire Safety Consultation"
    secondaryHref="/services"
    secondaryLabel="View All Services"
  />
</MainLayout>

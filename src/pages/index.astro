---
import MainLayout from '../layouts/MainLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import PrimaryButton from '../components/PrimaryButton.astro';
import SecondaryButton from '../components/SecondaryButton.astro';
import ServiceCard from '../components/ServiceCard.astro';
import FeatureCard from '../components/FeatureCard.astro';
import CtaBanner from '../components/CtaBanner.astro';
---

<MainLayout
	title="IronCore MEP | HVAC, Fire Alarm, Electromechanical & Building Maintenance Services in Abu Dhabi"
	description="IronCore MEP provides HVAC installation and maintenance, fire alarm systems support, electromechanical works, and building maintenance services in Musafha, Abu Dhabi."
>
	<section class="relative overflow-hidden bg-steel-900 py-24 text-white">
		<div class="absolute inset-0 opacity-30">
			<div class="h-full w-full bg-[radial-gradient(circle_at_top_left,#c1252d,transparent_45%),radial-gradient(circle_at_bottom_right,#374151,transparent_50%)]"></div>
		</div>
		<div class="container relative grid gap-10 lg:grid-cols-[1.2fr_0.8fr] lg:items-center">
			<div>
				<p class="text-sm font-semibold uppercase tracking-[0.2em] text-brand">Musafha, Abu Dhabi</p>
				<h1 class="mt-5 text-4xl font-extrabold leading-tight md:text-6xl">
					HVAC, Electromechanical, Fire Alarm & Building Maintenance Support
				</h1>
				<p class="mt-6 max-w-2xl text-lg text-steel-100/90">
					IronCore MEP delivers practical engineering-focused services for onshore and offshore requirements,
					including HVAC installation, maintenance, ducting, ventilation, and technical support.
				</p>
				<div class="mt-8 flex flex-wrap gap-3">
					<PrimaryButton href="/contact-us" label="Request a Quote" />
					<SecondaryButton href="/services" label="Explore Services" />
				</div>
			</div>
			<div class="card-base border-steel-700 bg-white/95 p-8 text-steel-800">
				<h2 class="text-xl font-semibold text-steel-900">Service Snapshot</h2>
				<ul class="mt-5 space-y-3 text-sm">
					<li class="flex items-center justify-between border-b border-steel-200 pb-2">
						<span>Location</span>
						<span class="font-semibold">Musafha, Abu Dhabi</span>
					</li>
					<li class="flex items-center justify-between border-b border-steel-200 pb-2">
						<span>Working Hours</span>
						<span class="font-semibold">8:00 AM to 5:00 PM</span>
					</li>
					<li class="flex items-center justify-between border-b border-steel-200 pb-2">
						<span>Service Area</span>
						<span class="font-semibold">Onshore & Offshore</span>
					</li>
				</ul>
				<a href="/contact-us" class="mt-6 inline-flex text-sm font-semibold text-brand hover:text-brand-dark">
					Contact for maintenance and quotations
				</a>
			</div>
		</div>
	</section>

	<section class="border-y border-steel-200 bg-steel-50 py-6">
		<div class="container grid gap-4 text-sm font-semibold text-steel-700 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-6">
			<p>Abu Dhabi Based</p>
			<p>Onshore & Offshore Support</p>
			<p>HVAC Installation & Maintenance</p>
			<p>Fire Alarm Systems</p>
			<p>Electromechanical Works</p>
			<p>Building Maintenance</p>
		</div>
	</section>

	<section class="section-space">
		<div class="container grid gap-10 lg:grid-cols-[1fr_1fr] lg:items-center">
			<div>
				<SectionHeading
					eyebrow="About IronCore MEP"
					title="Technical service delivery for commercial, industrial, and facility environments"
					description="IronCore MEP operates from Musafha, Abu Dhabi with focused support for HVAC, fire alarm systems, electromechanical works, and building maintenance. The team supports both onshore and offshore service requirements with practical execution and responsive coordination."
				/>
			</div>
			<div class="card-base bg-steel-900 p-8 text-white">
				<h3 class="text-2xl font-semibold">Legal Company Name</h3>
				<p class="mt-4 text-steel-200">
					IRON CORE ELECTROMECHANICAL WORKS AND BUILDING MAINTENANCE - L.L.C
				</p>
				<p class="mt-4 text-sm text-steel-300">
					Contact placeholders are currently active and will be replaced with final approved business details before launch.
				</p>
			</div>
		</div>
	</section>

	<section class="section-space bg-steel-50">
		<div class="container">
			<SectionHeading
				eyebrow="Core Services"
				title="Integrated MEP and maintenance support with HVAC depth"
				description="Explore detailed service capabilities across HVAC, Fire Alarm Systems, Electromechanical Works, and Building Maintenance."
			/>
			<div class="mt-10 grid gap-6 md:grid-cols-2">
				<ServiceCard
					title="HVAC Services"
					description="Installation, ducting, ventilation, chilled water line works, preventive maintenance, troubleshooting, and technical support for reliable cooling performance."
					points={['Chillers, AHUs, FCUs, packaged and split systems', 'GI/MS ducting and commercial ventilation works', 'Cleaning, servicing, refrigerant checks, and AMC support']}
					href="/hvac-services"
				/>
				<ServiceCard
					title="Fire Alarm Systems"
					description="Professional support for fire alarm system installation coordination, maintenance activities, inspections, and functional checks."
					points={['System layout and implementation support', 'Routine testing and fault diagnosis', 'Corrective maintenance planning']}
					href="/fire-alarm-systems"
				/>
				<ServiceCard
					title="Electromechanical Works"
					description="Execution support for mechanical and electrical building systems with attention to reliability, safety, and maintainability."
					points={['Electrical and mechanical system integration', 'Site execution coordination', 'Repair and upgrade support']}
					href="/electromechanical-works"
				/>
				<ServiceCard
					title="Building Maintenance"
					description="Planned and reactive maintenance support for core building systems to reduce downtime and improve equipment performance."
					points={['Preventive and corrective maintenance', 'System checks and performance tuning', 'Maintenance support for offices and facilities']}
					href="/building-maintenance"
				/>
			</div>
		</div>
	</section>

	<section class="section-space">
		<div class="container">
			<SectionHeading
				eyebrow="Why Choose Us"
				title="Execution-focused support built for practical site conditions"
				description="Our approach centers on realistic planning, clear communication, and service quality for ongoing operations."
			/>
			<div class="mt-10 grid gap-6 md:grid-cols-2 lg:grid-cols-4">
				<FeatureCard title="Professional Team" description="Engineers and technicians work with disciplined site procedures and clear scope alignment." />
				<FeatureCard title="Timely Delivery" description="Work planning prioritizes schedule reliability and coordinated execution." />
				<FeatureCard title="Quality-First Approach" description="Attention to workmanship and inspection helps maintain long-term system performance." />
				<FeatureCard title="Practical Solutions" description="Technical recommendations are focused on feasible operation, maintenance, and cost balance." />
				<FeatureCard title="Fair Commercial Terms" description="Pricing is structured for clarity and value across service and maintenance requests." />
				<FeatureCard title="Maintenance Support" description="Preventive and corrective service pathways help reduce avoidable equipment disruptions." />
				<FeatureCard title="Onshore & Offshore Reach" description="Service planning accommodates both onshore and offshore operational contexts." />
				<FeatureCard title="Responsive Coordination" description="Communication and site coordination stay active through execution and follow-up." />
			</div>
		</div>
	</section>

	<section class="section-space bg-steel-50">
		<div class="container">
			<SectionHeading
				eyebrow="Industries We Support"
				title="Service capabilities aligned to diverse facility needs"
				align="center"
			/>
			<div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
				{['Commercial', 'Industrial', 'Residential', 'Offices', 'Warehouses', 'Facilities & Accommodations', 'Onshore Operations', 'Offshore Operations'].map((sector) => (
					<div class="rounded-xl border border-steel-200 bg-white p-5 text-center font-semibold text-steel-700">{sector}</div>
				))}
			</div>
		</div>
	</section>

	<section class="section-space">
		<div class="container grid gap-8 lg:grid-cols-[1fr_1fr] lg:items-center">
			<div class="rounded-3xl border border-steel-200 bg-[linear-gradient(135deg,#111827,#1f2937)] p-8 text-white shadow-shell md:p-10">
				<p class="text-sm font-semibold uppercase tracking-[0.18em] text-brand">Featured HVAC Capability</p>
				<h2 class="mt-4 text-3xl font-bold leading-tight">From installation through commissioning and ongoing maintenance</h2>
				<p class="mt-4 text-steel-100/90">
					Our HVAC scope includes pre-engineering, feasibility support, installation, duct design and fabrication,
					testing and commissioning, preventive maintenance, AMC support, and troubleshooting.
				</p>
			</div>
			<div class="card-base p-8">
				<ul class="space-y-3 text-steel-700">
					<li>Installation of chillers, packaged AC units, AHUs, FCUs, ducted and split systems</li>
					<li>Chilled water pipeline works and chilled water pump installation</li>
					<li>GI and MS ducting installation with commercial and industrial ventilation</li>
					<li>System cleaning, coil and filter service, refrigerant checks, and leak detection</li>
					<li>Duct cleaning, sealing, inspection, and control optimization</li>
					<li>Testing, commissioning, maintenance modifications, and emergency troubleshooting</li>
				</ul>
				<a href="/hvac-services" class="mt-6 inline-flex text-sm font-semibold text-brand hover:text-brand-dark">
					View HVAC service details
				</a>
			</div>
		</div>
	</section>

	<CtaBanner
		title="Need a quotation or technical service support?"
		description="Contact IronCore MEP for HVAC, fire alarm, electromechanical, and building maintenance inquiries in Abu Dhabi."
		primaryHref="/contact-us"
		primaryLabel="Request a Quote"
		secondaryHref="/services"
		secondaryLabel="View All Services"
	/>
</MainLayout>

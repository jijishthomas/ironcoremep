---
import MainLayout from '../layouts/MainLayout.astro';
import PageHero from '../components/PageHero.astro';
import SectionHeading from '../components/SectionHeading.astro';
import ProjectTypeCard from '../components/ProjectTypeCard.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import PlaceholderNotice from '../components/PlaceholderNotice.astro';
import CtaBanner from '../components/CtaBanner.astro';

const representativeProjects = [
  {
    title: 'Commercial Fire Alarm Upgrade Program',
    summary: 'System upgrade support for conventional/addressable fire alarm coverage in occupied commercial properties.',
    scope: ['Design and device placement coordination', 'Installation, testing, and commissioning', 'Documentation and handover support'],
    href: '/fire-alarm-systems'
  },
  {
    title: 'Critical-Room Suppression Deployment',
    summary: 'Specialized suppression implementation for data centers and control rooms.',
    scope: ['FM-200 / clean agent system planning', 'Release logic testing and integration', 'Preventive maintenance pathway setup'],
    href: '/fire-suppression-systems'
  },
  {
    title: 'Warehouse Sprinkler and Pump Integration',
    summary: 'Automatic sprinkler and fire pump infrastructure support for large facility coverage.',
    scope: ['Sprinkler network installation support', 'Pump and pressure performance testing', 'Hydrant/landing valve coordination'],
    href: '/fire-sprinkler-systems'
  },
  {
    title: 'Firefighting Equipment Readiness Program',
    summary: 'Supply and service support for extinguishers, hose reels, hydrants, and related equipment.',
    scope: ['Equipment supply and installation', 'Inspection and servicing cycles', 'Refill/replacement coordination'],
    href: '/firefighting-equipment'
  },
  {
    title: 'Emergency Lighting and Evacuation Route Upgrade',
    summary: 'Emergency and exit light deployment for safer evacuation pathways during power loss events.',
    scope: ['Exit sign and luminaire placement', 'Routine testing and maintenance planning', 'Evacuation plan alignment'],
    href: '/emergency-lighting-exit-signs'
  },
  {
    title: 'Facility-Wide AMC Program',
    summary: 'Preventive maintenance and periodic testing for multi-system fire safety reliability.',
    scope: ['Scheduled inspections and performance tests', 'Rectification follow-up and records', 'Civil Defence audit support documentation'],
    href: '/annual-maintenance-contracts'
  },
  {
    title: 'Civil Defence Approval Coordination',
    summary: 'Documentation and inspection-readiness support from installation stage to final certification process.',
    scope: ['Submission and documentation support', 'Inspection preparation and follow-up', 'Coordination of corrective actions'],
    href: '/civil-defence-approvals'
  },
  {
    title: 'Onshore and Offshore Fire Safety Scope',
    summary: 'Integrated fire safety service coordination for projects and operational facilities across varied environments.',
    scope: ['Design, installation, and commissioning support', 'Maintenance and readiness planning', 'Approval and compliance workflow support'],
    href: '/services'
  }
];

const processSteps = [
  {
    title: 'Requirement Review',
    description: 'Understand site risks, occupancy profile, and system priorities.'
  },
  {
    title: 'Technical Assessment',
    description: 'Review existing conditions and define practical scope for each protection layer.'
  },
  {
    title: 'Scope Planning',
    description: 'Coordinate design, supply, installation, and testing sequence for implementation.'
  },
  {
    title: 'Execution',
    description: 'Carry out installation and system integration with stage-wise quality checks.'
  },
  {
    title: 'Testing & Commissioning',
    description: 'Verify performance and readiness through functional tests and commissioning records.'
  },
  {
    title: 'Handover & AMC Support',
    description: 'Support operational continuity with reporting, preventive maintenance, and approval coordination.'
  }
];
---

<MainLayout
  title="Projects & Fire Safety Application Scope | IronCore MEP Abu Dhabi"
  description="Explore representative project applications across fire alarm, suppression, sprinkler, pump, emergency lighting, AMC, and Civil Defence coordination."
>
  <PageHero
    title="Projects & Fire Safety Application Scope"
    description="IronCore MEP supports fire safety project and maintenance requirements across commercial, industrial, onshore, and offshore contexts in Abu Dhabi."
  />

  <section class="section-space">
    <div class="container">
      <SectionHeading
        eyebrow="Capabilities Overview"
        title="Representative support scope for project and maintenance requirements"
        description="This page presents representative application types to explain technical capabilities. Named case studies, client references, and portfolio visuals are added only after approved content is available."
      />
    </div>
  </section>

  <section class="section-space bg-steel-50">
    <div class="container">
      <SectionHeading
        eyebrow="Representative Project Types"
        title="Typical applications of our fire safety services"
      />
      <div class="mt-8 grid gap-6 md:grid-cols-2">
        {representativeProjects.map((item) => <ProjectTypeCard {...item} />)}
      </div>
    </div>
  </section>

  <section class="section-space">
    <div class="container">
      <SectionHeading
        eyebrow="Sectors We Support"
        title="Fire safety service coverage across varied environments"
      />
      <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {['Commercial Buildings', 'Industrial Facilities', 'Offices', 'Warehouses', 'Residential & Accommodation', 'Onshore Facilities', 'Offshore Operations', 'Mixed-Use Operational Sites'].map((sector) => (
          <div class="rounded-xl border border-steel-200 bg-white p-4 text-center text-sm font-semibold text-steel-700">{sector}</div>
        ))}
      </div>
    </div>
  </section>

  <section class="section-space bg-steel-50">
    <div class="container">
      <SectionHeading
        eyebrow="Work Approach"
        title="Delivery model used across fire safety assignments"
      />
      <div class="mt-8">
        <ProcessSteps steps={processSteps} />
      </div>
    </div>
  </section>

  <section class="section-space">
    <div class="container">
      <PlaceholderNotice
        title="Portfolio Reference Note"
        description="Detailed project references, client-named case studies, and approved project visuals are intentionally not published yet. These can be shared upon request or added in a future update once formally approved."
      />
    </div>
  </section>

  <CtaBanner
    title="Need support for an upcoming fire safety scope?"
    description="Contact IronCore MEP to discuss design, installation, testing and commissioning, AMC planning, or Civil Defence approval coordination."
    primaryHref="/contact-us"
    primaryLabel="Request a Site Assessment"
    secondaryHref="/services"
    secondaryLabel="Explore Services"
  />
</MainLayout>

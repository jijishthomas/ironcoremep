---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SeoHead from '../components/SeoHead.astro';
import { company } from '../data/site';
import { withBase } from '../utils/paths';
import '../styles/global.css';

interface Props {
	title: string;
	description: string;
	noindex?: boolean;
}

const { title, description, noindex = false } = Astro.props;

const maybeSite = Astro.site || new URL(company.siteUrl);
const isPlaceholderSite = maybeSite.hostname === 'localhost';
const sameAs = [company.socialLinkedIn, company.socialFacebook, company.socialInstagram].filter((link) =>
	link.startsWith('http://') || link.startsWith('https://')
);

const structuredData: Record<string, unknown>[] = [
	{
		'@context': 'https://schema.org',
		'@type': 'Organization',
		name: company.brandName,
		legalName: company.legalName,
		description: company.tagline,
		url: maybeSite.toString(),
		logo: new URL(withBase(company.logoPath), maybeSite).toString(),
		...(sameAs.length > 0 ? { sameAs } : {})
	},
	{
		'@context': 'https://schema.org',
		'@type': 'WebSite',
		name: company.brandName,
		url: maybeSite.toString()
	}
];
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="theme-color" content="#111827" />
		<link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
		<link rel="manifest" href={withBase('/site.webmanifest')} />
		<link rel="apple-touch-icon" href={withBase('/favicon.svg')} />
		<SeoHead title={title} description={description} noindex={isPlaceholderSite || noindex} />
		<script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
	</head>
	<body class="min-h-screen bg-white text-steel-800">
		<a href="#content" class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded-md focus:bg-brand focus:px-3 focus:py-2 focus:text-white">Skip to content</a>
		<Header />
		<main id="content">
			<slot />
		</main>
		<Footer />
	</body>
</html>
